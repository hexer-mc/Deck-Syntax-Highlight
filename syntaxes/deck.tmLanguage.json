{
  "scopeName": "source.deck",
  "name": "HexyCards Deck",
  "patterns": [
    { "include": "#metadata" },
    { "include": "#comment" },
    { "include": "#flashcardMcq" },
    { "include": "#flashcardSingle" },
    { "include": "#invalidLine" }
  ],
  "repository": {
    "metadata": {
      "patterns": [
        {
          "match": "^(@(?:title|lang|author):)(.*)$",
          "captures": {
            "1": { "name": "keyword.control.metadata.deck" },
            "2": { "name": "string.unquoted.metadata-value.deck" }
          }
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "match": "^#.*$",
          "name": "comment.line.number-sign.deck"
        }
      ]
    },
    "flashcardMcq": {
      "patterns": [
        {
          "begin": "^(?!#|@)(.*?)(\\s*::\\s*)([^|\\n]+)(?=\\s*\\|\\|)",
          "beginCaptures": {
            "1": { "name": "entity.name.question.deck" },
            "2": { "name": "punctuation.separator.answer.deck" },
            "3": { "name": "string.unquoted.answer.correct.deck" }
          },
          "end": "$",
          "patterns": [
            {
              "match": "\\|\\|",
              "name": "punctuation.separator.choice.deck"
            },
            {
              "match": "(?<=\\|\\|)\\s*[^|\\n]+",
              "name": "string.unquoted.answer.wrong.deck"
            }
          ]
        }
      ]
    },
    "flashcardSingle": {
      "patterns": [
        {
          "match": "^(?!#|@)(.*?)(\\s*::\\s*)([^|\\n]+)$",
          "captures": {
            "1": { "name": "entity.name.question.deck" },
            "2": { "name": "punctuation.separator.answer.deck" },
            "3": { "name": "string.unquoted.answer.deck" }
          }
        }
      ]
    },
    "invalidLine": {
      "patterns": [
        {
          "match": "^(?!#|@)(?!.*::).+$",
          "name": "invalid.illegal.unfinished-card.deck"
        }
      ]
    }
  }
}